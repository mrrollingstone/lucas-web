# ── App ──
PUBLIC_BASE_URL=https://lucas.hellohosty.com

# ── n8n workflow automation ──
N8N_BASE_URL=https://n8n.hellohosty.com
N8N_WEBHOOK_TOKEN=           # shared secret header for n8n calls

# ── Stripe (test mode until e2e passes) ──
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=             # multi-currency price ID
STRIPE_MEMBER_COUPON=        # 30% off coupon for HH members (optional until created)

# ── Cloudinary (cloud dptcyvz30, /lucas folder only) ──
CLOUDINARY_CLOUD_NAME=dptcyvz30
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=       # from env, never hardcode

# ── Mailchimp ──
MAILCHIMP_API_KEY=           # format: key-us21
MAILCHIMP_LIST_ID=           # audience ID

# ── Resend (email delivery) ──
RESEND_API_KEY=              # from resend.com, sender: notify.hellohosty.com

# ── HelloHosty auth ──
HH_JWT_SECRET=               # for verifying HH session cookies at /members/review
